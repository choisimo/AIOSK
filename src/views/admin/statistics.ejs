<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>통계 및 리포트</h2>
</div>

<form class="row g-3 align-items-end mb-4" method="get" action="/admin/statistics">
    <div class="col-md-4 col-lg-3">
        <label for="startDate" class="form-label">시작 날짜</label>
        <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startDate %>">
    </div>
    <div class="col-md-4 col-lg-3">
        <label for="endDate" class="form-label">종료 날짜</label>
        <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endDate %>">
    </div>
    <div class="col-md-4 col-lg-3">
        <button type="submit" class="btn btn-primary">필터 적용</button>
        <a href="/admin/statistics" class="btn btn-outline-secondary">초기화</a>
    </div>
</form>

<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6 class="card-title">총 매출</h6>
                <h3><%= overview.total_sales.toLocaleString() %>원</h3>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6 class="card-title">주문 수</h6>
                <h3><%= overview.total_orders.toLocaleString() %></h3>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6 class="card-title">평균 주문 금액</h6>
                <h3><%= Math.round(overview.average_order_value).toLocaleString() %>원</h3>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <h6 class="card-title">대기/준비</h6>
                <h3><%= (overview.pending_orders + overview.preparing_orders).toLocaleString() %></h3>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">일별 매출</h5></div>
            <div class="card-body"><canvas id="salesChart" height="120"></canvas></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">인기 메뉴</h5></div>
            <div class="card-body"><canvas id="popularMenuChart" height="120"></canvas></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h5 class="mb-0">카테고리별 매출</h5></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>카테고리</th>
                        <th>주문 수</th>
                        <th>판매 수량</th>
                        <th>매출</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (categoryStats.length > 0) { %>
                        <% categoryStats.forEach(function(category) { %>
                            <tr>
                                <td><%= category.category_name %></td>
                                <td><%= category.order_count.toLocaleString() %></td>
                                <td><%= category.total_quantity.toLocaleString() %></td>
                                <td><%= category.category_revenue.toLocaleString() %>원</td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">통계 데이터가 없습니다.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="/vendor/chart.js/chart.umd.js"></script>
<script>
const dailySales = <%- JSON.stringify(dailySales) %>.slice().reverse();
const topSellingMenus = <%- JSON.stringify(topSellingMenus) %>;

new Chart(document.getElementById('salesChart').getContext('2d'), {
    type: 'line',
    data: {
        labels: dailySales.map(item => item.sale_date ? new Date(item.sale_date).toLocaleDateString('ko-KR', { month: '2-digit', day: '2-digit' }) : '-'),
        datasets: [{
            label: '매출',
            data: dailySales.map(item => item.daily_sales),
            borderColor: 'rgb(75, 192, 192)',
            tension: 0.1
        }]
    },
    options: { responsive: true }
});

new Chart(document.getElementById('popularMenuChart').getContext('2d'), {
    type: 'doughnut',
    data: {
        labels: topSellingMenus.map(item => item.menu_name),
        datasets: [{
            data: topSellingMenus.map(item => item.total_quantity),
            backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF']
        }]
    },
    options: { responsive: true }
});
</script>
