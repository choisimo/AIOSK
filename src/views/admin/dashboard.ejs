<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="bi bi-speedometer2"></i>
        대시보드
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="refreshData()">
                <i class="bi bi-arrow-clockwise"></i>
                새로고침
            </button>
        </div>
    </div>
</div>

<!-- 핵심 지표 카드 -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            오늘 매출
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="todaySales">
                            <%= todayStatistics.totalSales ? todayStatistics.totalSales.toLocaleString() : '0' %>원
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-currency-dollar fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            오늘 주문 수
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="todayOrders">
                            <%= todayStatistics.orderCount || 0 %>건
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-receipt fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            평균 주문 금액
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="avgOrderValue">
                            <%= todayStatistics.averageOrderValue ? Math.round(todayStatistics.averageOrderValue).toLocaleString() : '0' %>원
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-calculator fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            대기 중 주문
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="pendingOrders">
                            <%= pendingOrdersCount || 0 %>건
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 차트 섹션 -->
<div class="row mb-4">
    <!-- 일별 매출 차트 -->
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-graph-up"></i>
                    일별 매출 현황 (최근 7일)
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-area">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- 인기 메뉴 차트 -->
    <div class="col-xl-4 col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-pie-chart"></i>
                    인기 메뉴 TOP 5
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-pie pt-4 pb-2">
                    <canvas id="popularMenuChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 최근 주문 및 알림 -->
<div class="row">
    <!-- 최근 주문 -->
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-clock-history"></i>
                    최근 주문
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>주문번호</th>
                                <th>금액</th>
                                <th>상태</th>
                                <th>시간</th>
                            </tr>
                        </thead>
                        <tbody id="recentOrdersTable">
                            <% if (recentOrders && recentOrders.length > 0) { %>
                                <% recentOrders.forEach(function(order) { %>
                                    <tr>
                                        <td>#<%= String(order.id).padStart(4, '0') %></td>
                                        <td><%= (order.totalPrice || 0).toLocaleString() %>원</td>
                                        <td>
                                            <span class="badge bg-<%= order.status === 'RECEIVED' ? 'warning' : order.status === 'PREPARING' ? 'info' : order.status === 'COMPLETED' ? 'success' : 'secondary' %>">
                                                <%= order.status === 'RECEIVED' ? '접수' : order.status === 'PREPARING' ? '준비중' : order.status === 'COMPLETED' ? '완료' : order.status %>
                                            </span>
                                        </td>
                                        <td><%= order.createdAt ? new Date(order.createdAt).toLocaleTimeString('ko-KR') : '-' %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted">최근 주문이 없습니다.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- 시스템 상태 -->
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-gear"></i>
                    시스템 상태
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <div class="text-center">
                            <i class="bi bi-server fa-2x text-success mb-2"></i>
                            <div class="small text-gray-500">백엔드 서버</div>
                            <div class="h6 text-success">정상</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <i class="bi bi-database fa-2x text-success mb-2"></i>
                            <div class="small text-gray-500">데이터베이스</div>
                            <div class="h6 text-success">정상</div>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-6">
                        <div class="text-center">
                            <i class="bi bi-display fa-2x text-<%= kioskStatus === 'online' ? 'success' : 'warning' %> mb-2"></i>
                            <div class="small text-gray-500">키오스크</div>
                            <div class="h6 text-<%= kioskStatus === 'online' ? 'success' : 'warning' %>">
                                <%= kioskStatus === 'online' ? '온라인' : '오프라인' %>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <i class="bi bi-wifi fa-2x text-success mb-2"></i>
                            <div class="small text-gray-500">실시간 연결</div>
                            <div class="h6 text-success" id="connectionStatus">연결됨</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// 차트 데이터 (서버에서 전달받은 데이터)
const salesData = <%- JSON.stringify(salesChartData || []) %>;
const popularMenuData = <%- JSON.stringify(popularMenuData || []) %>;

// 일별 매출 차트
const salesCtx = document.getElementById('salesChart').getContext('2d');
new Chart(salesCtx, {
    type: 'line',
    data: {
        labels: salesData.map(item => item.date),
        datasets: [{
            label: '매출액',
            data: salesData.map(item => item.sales),
            borderColor: 'rgb(75, 192, 192)',
            backgroundColor: 'rgba(75, 192, 192, 0.2)',
            tension: 0.1
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true,
                ticks: {
                    callback: function(value) {
                        return value.toLocaleString() + '원';
                    }
                }
            }
        }
    }
});

// 인기 메뉴 차트
const menuCtx = document.getElementById('popularMenuChart').getContext('2d');
new Chart(menuCtx, {
    type: 'doughnut',
    data: {
        labels: popularMenuData.map(item => item.menuName),
        datasets: [{
            data: popularMenuData.map(item => item.count),
            backgroundColor: [
                '#FF6384',
                '#36A2EB',
                '#FFCE56',
                '#4BC0C0',
                '#9966FF'
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false
    }
});

// 데이터 새로고침 함수
function refreshData() {
    location.reload();
}

// Socket.IO 연결 및 실시간 업데이트
const socket = io();

socket.on('connect', function() {
    document.getElementById('connectionStatus').textContent = '연결됨';
    document.getElementById('connectionStatus').className = 'h6 text-success';
});

socket.on('disconnect', function() {
    document.getElementById('connectionStatus').textContent = '연결 끊김';
    document.getElementById('connectionStatus').className = 'h6 text-danger';
});

// 새 주문 알림
socket.on('newOrder', function(orderData) {
    // 대기 중 주문 수 업데이트
    const pendingElement = document.getElementById('pendingOrders');
    const currentCount = parseInt(pendingElement.textContent);
    pendingElement.textContent = (currentCount + 1) + '건';
    
    // 최근 주문 테이블에 새 주문 추가
    const tableBody = document.getElementById('recentOrdersTable');
    const newRow = `
        <tr class="table-warning">
            <td>#${String(orderData.id).padStart(4, '0')}</td>
            <td>${(orderData.totalPrice || 0).toLocaleString()}원</td>
            <td><span class="badge bg-warning">접수</span></td>
            <td>${new Date().toLocaleTimeString('ko-KR')}</td>
        </tr>
    `;
    tableBody.insertAdjacentHTML('afterbegin', newRow);
    
    // 최대 10개 행만 유지
    const rows = tableBody.querySelectorAll('tr');
    if (rows.length > 10) {
        rows[rows.length - 1].remove();
    }
});

// 주문 상태 변경 알림
socket.on('orderStatusChanged', function(data) {
    // 대기 중 주문 수 업데이트 (완료된 경우)
    if (data.status === 'COMPLETED') {
        const pendingElement = document.getElementById('pendingOrders');
        const currentCount = Math.max(0, parseInt(pendingElement.textContent) - 1);
        pendingElement.textContent = currentCount + '건';
    }
});
</script>
