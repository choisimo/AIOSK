<div class="bg-light sidebar-sticky">
    <div class="sidebar-heading p-3">
        <h6 class="text-muted">관리 메뉴</h6>
    </div>
    
    <nav class="nav flex-column">
        <a class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" href="/admin">
            <i class="bi bi-speedometer2"></i>
            대시보드
        </a>
        
        <a class="nav-link <%= currentPage === 'orders' ? 'active' : '' %>" href="/admin/orders">
            <i class="bi bi-receipt"></i>
            주문 관리
        </a>
        
        <a class="nav-link <%= currentPage === 'menus' ? 'active' : '' %>" href="/admin/menus">
            <i class="bi bi-card-list"></i>
            메뉴 관리
        </a>
        
        <a class="nav-link <%= currentPage === 'categories' ? 'active' : '' %>" href="/admin/categories">
            <i class="bi bi-tags"></i>
            카테고리 관리
        </a>
        
        <a class="nav-link <%= currentPage === 'statistics' ? 'active' : '' %>" href="/admin/statistics">
            <i class="bi bi-graph-up"></i>
            통계 및 리포트
        </a>
        
        <div class="dropdown-divider my-3"></div>
        
        <h6 class="sidebar-heading px-3 text-muted">외부 링크</h6>
        
        <a class="nav-link" href="/api-docs" target="_blank">
            <i class="bi bi-book"></i>
            API 문서
            <i class="bi bi-box-arrow-up-right ms-1"></i>
        </a>
        
        <% if (kioskFrontendUrl) { %>
            <a class="nav-link" href="<%= kioskFrontendUrl %>" target="_blank">
                <i class="bi bi-display"></i>
                키오스크 화면
                <i class="bi bi-box-arrow-up-right ms-1"></i>
            </a>
        <% } %>
    </nav>
</div>

<style>
.sidebar-sticky {
    position: sticky;
    top: 0;
    height: calc(100vh - 48px);
    padding-top: .5rem;
    overflow-x: hidden;
    overflow-y: auto;
}

.nav-link {
    color: #333;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    margin: 0.125rem 0.75rem;
    transition: all 0.15s ease-in-out;
}

.nav-link:hover {
    color: #0056b3;
    background-color: #e9ecef;
}

.nav-link.active {
    color: #fff;
    background-color: #0d6efd;
}

.nav-link.active:hover {
    background-color: #0b5ed7;
}

.sidebar-heading {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}
</style>
