# ==========================================
# AIOSK 키오스크 백엔드 환경 변수 설정
# ==========================================
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값으로 수정하세요
# cp .env.example .env

# ==========================================
# 🗄️ 데이터베이스 설정 (MySQL)
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
# /run/secrets/* file paths are resolved under AIOSK_SECRETS_DIR when set.
# AIOSK_SECRETS_DIR=/run/secrets
# DB_PASSWORD_FILE=/run/secrets/db_password
DB_NAME=kiosk_db
DB_PORT=3306

# ==========================================
# 🔐 JWT 인증 설정
# ==========================================
# 보안을 위해 강력한 랜덤 키를 생성하세요
# 예: openssl rand -base64 64
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_characters_long
# 파일 기반 secret 주입도 지원합니다. JWT_SECRET과 JWT_SECRET_FILE을 동시에 설정하지 마세요.
# JWT_SECRET_FILE=/run/secrets/jwt_secret

# ==========================================
# 🌐 서버 설정
# ==========================================
PORT=3000
NODE_ENV=development
READINESS_DB_TIMEOUT_MS=2000
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
SHUTDOWN_TIMEOUT_MS=10000
# 브라우저/프론트 origin을 제한하려면 설정합니다. 비워두면 개발 환경에서 open CORS를 사용합니다.
# CORS_ORIGIN=http://localhost:5173

# ==========================================
# 📊 로깅 설정
# ==========================================
# 로그 레벨: error, warn, info, debug
LOG_LEVEL=info
LOG_DIR=logs

# ==========================================
# 📁 파일 업로드 설정
# ==========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ==========================================
# 🚀 Socket.IO 설정
# ==========================================
SOCKET_CORS_ORIGIN=http://localhost:3000
KIOSK_FRONTEND_URL=http://localhost:5173
# Swagger/OpenAPI servers.url. 비우면 현재 origin을 사용합니다.
# API_PUBLIC_URL=https://api.example.com

# ==========================================
# 🧑‍💼 관리자 세션 설정
# ==========================================
# 운영에서는 SESSION_SECRET을 32자 이상 랜덤 값으로 설정하고, HTTPS 뒤에서는 secure cookie를 사용하세요.
SESSION_SECRET=your_super_secure_session_secret_key_at_least_32_characters_long
# SESSION_SECRET_FILE=/run/secrets/session_secret
# 운영에서는 mysql을 사용합니다. 로컬 개발에서만 memory를 사용할 수 있습니다.
SESSION_STORE=memory
SESSION_CLEANUP_INTERVAL_MS=900000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE_MS=86400000
# Reverse proxy 뒤에서 secure cookie를 쓸 때 1로 설정합니다.
TRUST_PROXY=0

# ==========================================
# 🖥️ 키오스크 상태 수집 설정 (선택사항)
# ==========================================
# 설정하면 /api/public/kiosk/status 요청에 x-kiosk-status-token 또는 Bearer 토큰이 필요합니다.
# KIOSK_STATUS_TOKEN=kiosk_status_token_at_least_16_chars
# KIOSK_STATUS_TOKEN_FILE=/run/secrets/kiosk_status_token

# ==========================================
# 📈 모니터링 설정 (선택사항)
# ==========================================
# 설정하면 /metrics 요청에 x-metrics-token 또는 Bearer 토큰이 필요합니다.
# 운영에서는 METRICS_TOKEN 또는 METRICS_TOKEN_FILE이 필요하며, 토큰 없이 열려면 ALLOW_OPEN_METRICS=true를 명시해야 합니다.
# METRICS_TOKEN=change_this_metrics_token
# METRICS_TOKEN_FILE=/run/secrets/metrics_token
# ALLOW_OPEN_METRICS=false

# ==========================================
# 🧾 DB 백업 설정 (선택사항)
# ==========================================
# BACKUP_DIR=backups
# BACKUP_VERIFY=1
# BACKUP_RETENTION_DAYS=14
# BACKUP_MIN_KEEP=7
# BACKUP_REMOTE_DIR=/mnt/aiosk-backups

# ==========================================
# 👤 관리자 계정 부트스트랩 (선택사항)
# ==========================================
# 실제 운영 비밀번호를 이 예시 파일에 커밋하지 마세요.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_this_to_a_strong_password
# ADMIN_PASSWORD_FILE=/run/secrets/admin_password
