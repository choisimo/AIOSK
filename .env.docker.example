COMPOSE_DB_NAME=kiosk_db
COMPOSE_DB_USER=aiosk
COMPOSE_DB_PASSWORD=change_this_database_password
COMPOSE_MYSQL_ROOT_PASSWORD=change_this_root_password

JWT_SECRET=change_this_to_at_least_32_characters
SESSION_SECRET=change_this_session_secret
SESSION_STORE=mysql
SESSION_CLEANUP_INTERVAL_MS=900000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE_MS=86400000
TRUST_PROXY=0
KIOSK_STATUS_TOKEN=
# Browser-visible copy used by React heartbeat only when KIOSK_STATUS_TOKEN is enabled.
# FRONTEND_KIOSK_STATUS_TOKEN=kiosk_status_token_at_least_16_chars
CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:3000
KIOSK_FRONTEND_URL=http://localhost:5173
# API_PUBLIC_URL=https://api.example.com
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
# 설정하면 /metrics 요청에 x-metrics-token 또는 Bearer 토큰이 필요합니다.
# Prometheus compose profile을 함께 쓸 경우 prometheus.yml에도 같은 인증 설정을 반영하세요.
# METRICS_TOKEN=change_this_metrics_token
ALLOW_OPEN_METRICS=false
LOG_LEVEL=info
LOG_DIR=logs
NODE_ENV=development
READINESS_DB_TIMEOUT_MS=2000
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
SHUTDOWN_TIMEOUT_MS=10000

FRONTEND_API_URL=http://localhost:3000
VITE_ALLOW_LOCAL_API_URL=true
FRONTEND_APP_VERSION=docker-local

# Optional backup settings for scripts/db-backup.sh
# BACKUP_DIR=backups
# BACKUP_VERIFY=1
# BACKUP_RETENTION_DAYS=14
# BACKUP_MIN_KEEP=7
# BACKUP_REMOTE_DIR=/mnt/aiosk-backups
# BACKUP_UPLOAD_COMMAND='rclone copy "$BACKUP_FILE" "remote:aiosk-backups/$BACKUP_DB_NAME/"'

# Optional monitoring profile ports and Grafana credentials
# COMPOSE_PROMETHEUS_PORT=9090
# COMPOSE_ALERTMANAGER_PORT=9093
# COMPOSE_GRAFANA_PORT=3001
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_this_grafana_password
