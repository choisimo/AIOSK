VITE_API_URL=http://localhost:3000
VITE_ALLOW_LOCAL_API_URL=true
VITE_USE_MOCK_DATA=false
VITE_APP_VERSION=local
# Optional browser-visible heartbeat token. Set only when backend KIOSK_STATUS_TOKEN is enabled.
# Must match the backend token, be at least 16 characters, and contain no whitespace.
VITE_KIOSK_STATUS_TOKEN=
