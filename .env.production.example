COMPOSE_DB_NAME=kiosk_db
COMPOSE_DB_USER=aiosk
COMPOSE_DB_PASSWORD=change_this_database_password
COMPOSE_MYSQL_ROOT_PASSWORD=change_this_root_password

JWT_SECRET=replace_with_random_jwt_secret_at_least_32_chars
SESSION_SECRET=replace_with_random_session_secret_at_least_32_chars
# Secret-manager synced file alternatives are supported for backend app secrets.
# Do not set both a value and its *_FILE counterpart in the same environment.
# In compose deployments, *_FILE values are container paths under /run/secrets;
# AIOSK_SECRETS_DIR points to the matching host directory mounted there.
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# SESSION_SECRET_FILE=/run/secrets/session_secret
# AIOSK_SECRETS_DIR=/run/secrets
SESSION_STORE=mysql
SESSION_CLEANUP_INTERVAL_MS=900000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE_MS=86400000
TRUST_PROXY=1
KIOSK_STATUS_TOKEN=
METRICS_TOKEN=
ALLOW_OPEN_METRICS=false
# KIOSK_STATUS_TOKEN_FILE=/run/secrets/kiosk_status_token
# METRICS_TOKEN_FILE=/run/secrets/metrics_token
LOG_LEVEL=info
LOG_DIR=logs
READINESS_DB_TIMEOUT_MS=2000
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
SHUTDOWN_TIMEOUT_MS=10000
# Comma-separated origins. Leave empty only if another edge layer enforces origin policy.
CORS_ORIGIN=https://kiosk.example.com
SOCKET_CORS_ORIGIN=https://admin.example.com
KIOSK_FRONTEND_URL=https://kiosk.example.com
# Optional absolute public API URL for Swagger/OpenAPI. Defaults to current origin.
# API_PUBLIC_URL=https://api.example.com
ALLOW_OPEN_CORS=false
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

AIOSK_BACKEND_IMAGE=ghcr.io/example-owner/aiosk-backend:v1.0.0
AIOSK_FRONTEND_IMAGE=ghcr.io/example-owner/aiosk-frontend:v1.0.0

COMPOSE_BACKEND_PORT=3000
COMPOSE_FRONTEND_PORT=5173
COMPOSE_BACKEND_BIND=0.0.0.0
COMPOSE_FRONTEND_BIND=0.0.0.0
COMPOSE_DB_BIND=127.0.0.1
COMPOSE_DB_PORT=3306

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password
COMPOSE_MONITORING_BIND=127.0.0.1
COMPOSE_PROMETHEUS_PORT=9090
COMPOSE_ALERTMANAGER_PORT=9093
COMPOSE_GRAFANA_PORT=3001

BACKUP_DIR=/var/backups/aiosk
BACKUP_VERIFY=1
BACKUP_RETENTION_DAYS=14
BACKUP_MIN_KEEP=7
# Production preflight requires BACKUP_REMOTE_DIR or BACKUP_UPLOAD_COMMAND unless local-only backups are accepted intentionally.
# BACKUP_REMOTE_DIR=/mnt/aiosk-backups
# BACKUP_UPLOAD_COMMAND='rclone copy "$BACKUP_FILE" "remote:aiosk-backups/$BACKUP_DB_NAME/"'
